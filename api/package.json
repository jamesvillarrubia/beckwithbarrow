{
  "name": "my-strapi-project",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "seed:example": "node ./scripts/seed.js",
    "start": "strapi start",
    "strapi": "strapi",
    "upgrade": "npx @strapi/upgrade lantest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry",
    "backup": "./scripts/backup.sh",
    "backup:quick": "strapi export --file backups/quick-backup-$(date +%Y%m%d-%H%M%S) --no-encrypt",
    "backup:verbose": "VERBOSE=true ./scripts/backup.sh",
    "backup:silent": "VERBOSE=false ./scripts/backup.sh",
    "backup:cloud": "./scripts/cloud-backup.sh",
    "backup:cloud:verbose": "VERBOSE=true ./scripts/cloud-backup.sh",
    "backup:cloud:config": "./scripts/cloud-backup.sh --config",
    "deploy:cloud": "./scripts/cloud-deploy.sh",
    "deploy:cloud:help": "./scripts/cloud-deploy.sh --help",
    "deploy:cloud:dry-run": "./scripts/cloud-deploy.sh --dry-run",
    "restore": "strapi import --no-encrypt",
    "backup:list": "ls -la backups/strapi-backup-*.tar.gz 2>/dev/null || echo 'No backups found'",
    "backup:cloud:list": "ls -la backups/cloud/strapi-cloud-backup-*.tar.gz 2>/dev/null || echo 'No cloud backups found'"
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.23.4",
    "@strapi/plugin-users-permissions": "5.23.4",
    "@strapi/strapi": "5.23.4",
    "axios": "^1.12.2",
    "better-sqlite3": "11.3.0",
    "form-data": "^4.0.4",
    "fs-extra": "^10.0.0",
    "image-size": "^2.0.2",
    "mime-types": "^2.1.27",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "sharp": "^0.34.4",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "85303aae-2e14-4214-a473-c74bff36f56c",
    "installId": "74e1c263007dea05ab286cd06c882964ea8f705730a5da0bf23806e87964aac7"
  }
}
