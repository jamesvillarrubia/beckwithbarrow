# Leading slashes anchor these to the repository root. Without them, gitignore
# semantics match a directory of that name at ANY depth — which silently excluded
# packages/cms-mcp/api/, so Vercel reported "no Serverless Functions inside the api
# directory" for the MCP project.
/api/
/docs/
/scripts/
/uploads/
*.log
