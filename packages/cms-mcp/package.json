{
  "name": "@beckwithbarrow/cms-mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Layer B \u2014 MCP server exposing the safe-write CMS client as tools. Holds no token logic of its own.",
  "scripts": {
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "pnpm --filter @beckwithbarrow/cms-client build && tsup"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "@beckwithbarrow/cms-client": "workspace:*",
    "tsup": "^8.5.1",
    "@types/node": "^22.0.0"
  }
}
